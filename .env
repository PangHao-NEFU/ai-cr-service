# AI Code Review Service Configuration

# Server Settings
APP_NAME=AI Code Review Service
DEBUG=true
HOST=0.0.0.0
PORT=8000

# GitLab Settings
GITLAB_URL=https://gitlab.example.com
GITLAB_PRIVATE_TOKEN=your_gitlab_token_here
GITLAB_VERIFY_SSL=true

# LLM Settings
LLM_PROVIDER=openai
LLM_API_KEY=19181bae-d385-4583-abe0-a3aa239b8485
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-2-0-mini-260215
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Redis Settings
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# Code Review Settings
CR_CONTEXT_LINES=20
CR_MAX_CONTEXT_FILES=5

# Security Settings
WEBHOOK_SECRET=
