# AI Code Review Service Configuration
# Copy this file to .env and fill in your values

# Server Settings
APP_NAME=AI Code Review Service
DEBUG=false
HOST=0.0.0.0
PORT=8000

# GitLab Settings
GITLAB_URL=https://gitlab.example.com
GITLAB_PRIVATE_TOKEN=your_gitlab_private_token
GITLAB_VERIFY_SSL=true

# LLM Settings
# Provider: openai, anthropic, custom (兼容 OpenAI 协议的模型如 DeepSeek、Qwen)
LLM_PROVIDER=openai
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=  # Optional: for custom provider (公司私有模型地址)
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1  # 低温度保证稳定输出
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120

# Security Settings
WEBHOOK_SECRET=your_webhook_secret

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
